{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Auth microservice for Kit Grail",
  "license": "UNLICENSED",
  "type": "commonjs",
  "scripts": {
    "swagger": "tsoa spec-and-routes",
    "prebuild": "npm run swagger",
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node build/server.js",
    "predev": "npm run swagger",
    "dev": "concurrently \"nodemon\" \"nodemon -x tsoa spec-and-routes\"",
    "lint": "eslint src/**/*.ts --fix",
    "cpd": "jscpd src --silent",
    "pretest": "(npm run swagger) && (npm run lint) && (npm run cpd)",
    "test": "vitest run --no-file-parallelism --testTimeout=3000 --coverage",
    "rtest": "vitest run --no-file-parallelism --testTimeout=3000 --coverage"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jose": "^5.10.0",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jscpd": "^4.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsoa": "^7.0.0-alpha.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "src/build/**"
    ],
    "exec": "ts-node src/server.ts"
  }
}
