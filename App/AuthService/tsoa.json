{
  "entryFile": "src/app.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["src/**/controller.ts"],
  "spec": {
    "outputDirectory": "src/build",
    "specVersion": 3,
    "basePath": "/api/v0",
    "securityDefinitions": {
      "jwt": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "routes": {
    "routesDir": "src/build",
    "authenticationModule": "./src/auth/express.ts"
  }
}
