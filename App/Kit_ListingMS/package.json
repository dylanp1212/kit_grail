{
  "name": "kit_listing-ms",
  "version": "0.0.0",
  "repository": "none",
  "devDependencies": {
    "@eslint/js": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "*",
    "@types/express": "*",
    "@types/jsonwebtoken": "*",
    "@types/node": "*",
    "@types/pg": "*",
    "@types/supertest": "*",
    "@types/swagger-ui-express": "*",
    "@vitest/coverage-v8": "*",
    "bestzip": "*",
    "concurrently": "*",
    "eslint": "*",
    "eslint-config-typescript": "*",
    "globals": "*",
    "joi": "*",
    "jscpd": "*",
    "nodemon": "*",
    "supertest": "*",
    "ts-node": "*",
    "ts-postgres": "*",
    "typescript": "*",
    "typescript-eslint": "*",
    "vite-plugin-eslint": "*",
    "vitest": "*"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "*",
    "dotenv": "*",
    "express": "*",
    "jsonwebtoken": "*",
    "pg": "*",
    "swagger-ui-express": "*",
    "tsoa": "*"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "exec": "ts-node src/server.ts"
  },
  "scripts": {
    "prestart": "npm run build",
    "start": "node build/src/server.js",
    "prebuild": "npm run swagger",
    "build": "tsc",
    "predev": "npm run swagger",
    "dev": "concurrently \"nodemon\" \"nodemon -x tsoa spec-and-routes\"",
    "swagger": "tsoa spec-and-routes",
    "pretest": "(npm run swagger) && (npm run lint) && (npm run cpd)",
    "test": "vitest run --no-file-parallelism --testTimeout=3000 --coverage",
    "rtest": "vitest run --no-file-parallelism --testTimeout=3000 --coverage",
    "cpd": "jscpd src test --silent",
    "lint": "eslint test/**/*.[jt]s src/**/*.[jt]s --fix",
    "zip": "bestzip CSE187.Assignment1.Submission.zip test/* src/*/* sql/schema.sql"
  }
}
