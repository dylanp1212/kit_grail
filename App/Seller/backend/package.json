{
  "name": "seller",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prestart": "npm run build",
    "start": "node build/src/app.js",
    "prebuild": "npm run swagger",
    "build": "tsc",
    "predev": "npm run swagger",
    "dev": "concurrently \"nodemon\" \"nodemon -x tsoa spec-and-routes\"",
    "swagger": "tsoa spec-and-routes",
    "pretest": "(npm run swagger) && (npm run lint) && (npm run cpd)",
    "test": "vitest run --no-file-parallelism --testTimeout=3000 --coverage",
    "rtest": "vitest run --no-file-parallelism --testTimeout=3000 --coverage",
    "cpd": "jscpd src test --silent",
    "lint": "eslint test/**/*.[jt]s src/**/*.[jt]s --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "swagger-ui-express": "^5.0.1"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "ignore": ["src/build/**"],
    "exec": "ts-node src/server.ts"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/swagger-ui-express": "^4.1.8",
    "concurrently": "^9.2.1",
    "install": "^0.13.0",
    "joi": "^18.1.2",
    "nodemon": "^3.1.14",
    "npm": "^11.13.0",
    "ts-node": "^10.9.2",
    "tsoa": "^7.0.0-alpha.0",
    "typescript": "^6.0.3"
  }
}
