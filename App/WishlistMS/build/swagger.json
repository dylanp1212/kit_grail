{
	"openapi": "3.0.0",
	"components": {
		"examples": {},
		"headers": {},
		"parameters": {},
		"requestBodies": {},
		"responses": {},
		"schemas": {
			"Size": {
				"type": "string",
				"enum": [
					"xsmall",
					"small",
					"medium",
					"large",
					"xlarge"
				]
			},
			"WishlistItem": {
				"properties": {
					"id": {
						"type": "string"
					},
					"seller": {
						"type": "string"
					},
					"title": {
						"type": "string"
					},
					"description": {
						"type": "string"
					},
					"size": {
						"$ref": "#/components/schemas/Size"
					},
					"colors": {
						"items": {
							"type": "string"
						},
						"type": "array"
					},
					"listed": {
						"type": "string",
						"format": "date-time"
					},
					"price": {
						"type": "number",
						"format": "double"
					},
					"image": {
						"type": "string"
					},
					"added": {
						"type": "string",
						"format": "date-time"
					}
				},
				"required": [
					"id",
					"seller",
					"title",
					"description",
					"size",
					"colors",
					"listed",
					"price",
					"added"
				],
				"type": "object",
				"additionalProperties": false
			}
		},
		"securitySchemes": {}
	},
	"info": {
		"title": "kit_listing-ms",
		"version": "0.0.0",
		"contact": {}
	},
	"paths": {
		"/wishlist/{userid}": {
			"get": {
				"operationId": "GetAllWishlistItems",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"items": {
										"$ref": "#/components/schemas/WishlistItem"
									},
									"type": "array"
								}
							}
						}
					},
					"400": {
						"description": "Invalid user ID format"
					}
				},
				"security": [],
				"parameters": [
					{
						"in": "path",
						"name": "userid",
						"required": true,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "query",
						"name": "search",
						"required": false,
						"schema": {
							"type": "string"
						}
					}
				]
			}
		},
		"/wishlist/{userid}/{listingid}": {
			"get": {
				"operationId": "CheckInWishlist",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"type": "boolean"
								}
							}
						}
					},
					"400": {
						"description": "Invalid ID format"
					}
				},
				"security": [],
				"parameters": [
					{
						"in": "path",
						"name": "userid",
						"required": true,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "path",
						"name": "listingid",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				]
			},
			"post": {
				"operationId": "AddToWishlist",
				"responses": {
					"201": {
						"description": "Added to wishlist",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/WishlistItem"
								}
							}
						}
					},
					"400": {
						"description": "Invalid ID format"
					},
					"409": {
						"description": "Already in wishlist"
					}
				},
				"security": [],
				"parameters": [
					{
						"in": "path",
						"name": "userid",
						"required": true,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "path",
						"name": "listingid",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				]
			},
			"delete": {
				"operationId": "RemoveFromWishlist",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"type": "string"
								}
							}
						}
					},
					"400": {
						"description": "Invalid ID format"
					}
				},
				"security": [],
				"parameters": [
					{
						"in": "path",
						"name": "userid",
						"required": true,
						"schema": {
							"type": "string"
						}
					},
					{
						"in": "path",
						"name": "listingid",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				]
			}
		}
	},
	"servers": [
		{
			"url": "/api/v0"
		}
	]
